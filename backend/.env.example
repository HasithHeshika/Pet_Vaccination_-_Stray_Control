# Database Configuration
# IMPORTANT FOR GROUP PROJECTS: Use MongoDB Atlas (Cloud Database)
# Get connection string from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority
# All team members should use the SAME MongoDB Atlas cluster
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/pet_management?retryWrites=true&w=majority
MONGO_ROOT_USERNAME=mongodb_username
MONGO_ROOT_PASSWORD=mongodb_password
MONGO_DATABASE=pet_management

# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=dev-jwt-secret-key-change-in-production

# Admin User Configuration
ADMIN_EMAIL=admin@petmanagement.com
ADMIN_PASSWORD=Admin@123

# Email Configuration (SMTP)
# For Gmail: smtp.gmail.com, Port: 587
# For Outlook: smtp.office365.com, Port: 587
# For development, leave empty to use Ethereal (test email service)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Pet Management System <noreply@petmanagement.com>

# Vaccination Scheduler Configuration
# Cron expression for daily reminder check (default: 9 AM daily)
# Format: minute hour day month dayOfWeek
# Examples:
#   0 9 * * * = Every day at 9:00 AM
#   0 8,12,18 * * * = Every day at 8 AM, 12 PM, and 6 PM
#   */30 * * * * = Every 30 minutes
REMINDER_CRON=0 9 * * *

# SMS Configuration (Optional - for future Twilio integration)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
